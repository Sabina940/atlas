---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { supabase } from "../../lib/supabaseClient";
import { CATEGORIES, CATEGORY_KEYS, getCategory } from "../../lib/categories";

const { cat } = Astro.params;

if (!cat || !CATEGORY_KEYS.includes(cat as any)) {
  return Astro.redirect("/posts");
}

const catKey = cat as keyof typeof CATEGORIES;
const catDef = CATEGORIES[catKey];

type Post = {
  id: string;
  title: string;
  slug: string;
  excerpt: string | null;
  cover_url: string | null;
  category: string | null;
  rating: number | null;
  created_at: string;
};

const { data: posts, error } = await supabase
  .from("posts")
  .select("id,title,slug,excerpt,cover_url,category,rating,created_at")
  .eq("status", "published")
  .eq("category", catKey)
  .order("created_at", { ascending: false });

const list = (posts ?? []) as Post[];

const fmt = (iso: string) =>
  new Date(iso).toLocaleDateString("en-GB", { year: "numeric", month: "short", day: "2-digit" });

function renderStars(rating: number | null) {
  if (!rating) return null;
  const filled = Math.round(Math.max(1, Math.min(5, rating)));
  return Array.from({ length: 5 }, (_, i) => i < filled);
}
---

<BaseLayout
  title={`${catDef.label} — Atlas`}
  description={`Reviews of ${catDef.label.toLowerCase()} — honest notes from the road.`}
>
  <main class="pageWrap">
    <header class="pageHero">
      <a class="pageHeroBack" href="/posts">← All Reviews</a>

      <div class="pageHeroEyebrow">
        <span class="catBadge" data-cat={catKey}>{catDef.icon} {catDef.label}</span>
      </div>

      <h1 class="pageHeroTitle">{catDef.label}</h1>
      <p class="pageHeroSub">
        {list.length} review{list.length !== 1 ? "s" : ""} published.
      </p>
    </header>

    <nav class="catFilterRow" aria-label="All categories">
      {CATEGORY_KEYS.filter((k) => k !== catKey).map((key) => {
        const c = CATEGORIES[key];
        return (
          <a class="catChip" href={`/category/${key}`} data-cat={key}>
            {c.icon} {c.label}
          </a>
        );
      })}
    </nav>

    {error && <p class="error">Couldn't load reviews.</p>}

    {list.length > 0 && (
      <div class="grid">
        {list.map((p) => {
          const pcat = getCategory(p.category);
          const stars = renderStars(p.rating);
          return (
            <a class="revCard" href={`/posts/${p.slug}`}>
              <div class="revCardImg">
                {p.cover_url
                  ? <img src={p.cover_url} alt="" loading="lazy" />
                  : <div class="revCardImgPh">{pcat?.icon ?? catDef.icon}</div>
                }
              </div>
              <div class="revCardBody">
                <h2 class="revCardTitle">{p.title}</h2>
                {stars && (
                  <div class="stars" aria-label={`${p.rating} out of 5`}>
                    {stars.map((on) => (
                      <span class={on ? "star on" : "star"}>★</span>
                    ))}
                  </div>
                )}
                {p.excerpt && <p class="revCardExcerpt">{p.excerpt}</p>}
                <div class="revCardFoot">
                  <span class="revCardDate">{fmt(p.created_at)}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}

    {list.length === 0 && !error && (
      <div class="emptyState">
        <div class="emptyStateIcon">{catDef.icon}</div>
        <p class="emptyStateText">No {catDef.label.toLowerCase()} reviews yet.</p>
      </div>
    )}
  </main>
</BaseLayout>
