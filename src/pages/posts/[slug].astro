---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { supabase } from "../../lib/supabaseClient";
import { marked, Renderer } from "marked";

// Open external links in a new tab
const renderer = new Renderer();
renderer.link = ({ href, title, text }: { href: string; title?: string | null; text: string }) => {
  const isExternal = href?.startsWith("http");
  const titleAttr = title ? ` title="${title}"` : "";
  const target = isExternal ? ` target="_blank" rel="noopener noreferrer"` : "";
  return `<a href="${href}"${titleAttr}${target}>${text}</a>`;
};
import { CommentsSection } from "../../components/comments/CommentsSection";
import { getCategory } from "../../lib/categories";

const { slug } = Astro.params;

type Post = {
  id: string;
  title: string;
  slug: string;
  content_md: string;
  excerpt: string | null;
  cover_url: string | null;
  category: string | null;
  rating: number | null;
  created_at: string;
};

if (!slug) return Astro.redirect("/posts");

const { data: post, error } = await supabase
  .from("posts")
  .select("id,title,slug,content_md,excerpt,cover_url,category,rating,created_at")
  .eq("slug", slug)
  .eq("status", "published")
  .single();

if (error || !post) return Astro.redirect("/posts");

const p = post as Post;
const cat = getCategory(p.category);

function stripAdminHeader(md: string) {
  const lines = (md ?? "").split("\n");
  const filtered = lines.filter((line) => {
    const t = line.trim();
    if (!t) return true;
    return !/^(Title:|Slug:|Tags:|Cover_url:|Category:|Rating:)\s*/i.test(t);
  });
  return filtered.join("\n").trim();
}

const cleanedMd = stripAdminHeader(p.content_md ?? "");
const html = await marked.parse(cleanedMd, { renderer });

const fmt = (iso: string) =>
  new Date(iso).toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "2-digit",
  });

function renderStars(rating: number | null) {
  if (!rating) return null;
  const filled = Math.round(Math.max(1, Math.min(5, rating)));
  return Array.from({ length: 5 }, (_, i) => i < filled);
}

const stars = renderStars(p.rating);
---

<BaseLayout
  title={`Atlas — ${p.title}`}
  description={p.excerpt ?? undefined}
  ogImage={p.cover_url ?? undefined}
>
  <main class="postPage">
    <header class="postHeader">
      <a class="postBack" href="/posts">← All Reviews</a>

      <div class="postMeta">
        {cat && (
          <span class="catBadge" data-cat={p.category}>
            {cat.icon} {cat.label}
          </span>
        )}
        <span class="postDate">{fmt(p.created_at)}</span>
      </div>

      <h1 class="postTitle">{p.title}</h1>

      {stars && (
        <div class="postRating">
          <div class="stars" aria-label={`Rated ${p.rating} out of 5`}>
            {stars.map((on) => (
              <span class={on ? "star on" : "star"}>★</span>
            ))}
          </div>
          <span class="postRatingNum">{p.rating}/5</span>
        </div>
      )}

      {p.excerpt && <p class="postExcerpt">{p.excerpt}</p>}
    </header>

    {p.cover_url && (
      <figure class="postCover" id="postCover">
        <img src={p.cover_url} alt="" />
      </figure>
    )}

    <article class="postContent" set:html={html} />

    <section class="postComments cWrap">
      <CommentsSection client:load postId={p.id} />
    </section>
  </main>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-hidden="true">
    <button class="lbClose" id="lbClose" aria-label="Close">✕</button>
    <button class="lbArrow lbPrev" id="lbPrev" aria-label="Previous">‹</button>
    <button class="lbArrow lbNext" id="lbNext" aria-label="Next">›</button>
    <img id="lbImg" src="" alt="" />
    <div class="lbCounter" id="lbCounter"></div>
  </div>

  <script is:inline>
    (function () {
      var lb = document.getElementById('lightbox');
      var lbImg = document.getElementById('lbImg');
      var lbClose = document.getElementById('lbClose');
      var lbPrev = document.getElementById('lbPrev');
      var lbNext = document.getElementById('lbNext');
      var lbCounter = document.getElementById('lbCounter');
      var images = [];
      var current = 0;

      function show(srcs, idx) {
        images = srcs;
        current = idx;
        lbImg.src = srcs[idx];
        lb.classList.add('open');
        lb.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        update();
      }

      function close() {
        lb.classList.remove('open');
        lb.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      function go(dir) {
        current = Math.max(0, Math.min(images.length - 1, current + dir));
        lbImg.src = images[current];
        update();
      }

      function update() {
        lbPrev.style.visibility = current === 0 ? 'hidden' : 'visible';
        lbNext.style.visibility = current === images.length - 1 ? 'hidden' : 'visible';
        lbCounter.textContent = images.length > 1 ? (current + 1) + ' / ' + images.length : '';
      }

      // Gallery images
      var galleryImgs = document.querySelectorAll('.postContent .gallery img');
      var galSrcs = Array.from(galleryImgs).map(function(i) { return i.src; });
      galleryImgs.forEach(function(img, i) {
        img.addEventListener('click', function() { show(galSrcs, i); });
      });

      // Cover image
      var cover = document.getElementById('postCover');
      if (cover) {
        cover.addEventListener('click', function() {
          show([cover.querySelector('img').src], 0);
        });
      }

      lbClose.addEventListener('click', close);
      lbPrev.addEventListener('click', function() { go(-1); });
      lbNext.addEventListener('click', function() { go(1); });
      lb.addEventListener('click', function(e) { if (e.target === lb) close(); });

      document.addEventListener('keydown', function(e) {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') go(-1);
        if (e.key === 'ArrowRight') go(1);
      });
    })();
  </script>
</BaseLayout>
